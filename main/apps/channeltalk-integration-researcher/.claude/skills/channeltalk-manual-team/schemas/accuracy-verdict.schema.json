{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accuracy verdict — channeltalk-manual 산출의 지어냄 적발",
  "type": "object",
  "required": ["count", "verdict"],
  "additionalProperties": false,
  "properties": {
    "count": {
      "type": "number",
      "minimum": 0,
      "description": "SSOT(surface features · CHANNELTALK.md §12) 대조 시 지어낸 엔드포인트/필드/auth 헤더/provenance 단정 총 개수. minimize, ==0 이면 통과"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "revise"],
      "description": "pass = count == 0"
    },
    "offenders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "지어낸 항목 식별자 (예: path:/open/v5/foo, field:xToken, header:x-made-up)"
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["where", "problem", "fix"],
        "additionalProperties": false,
        "properties": {
          "where": { "type": "string", "description": "섹션/기능 id" },
          "problem": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    }
  }
}
