{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "completeness verdict — changes 신규 id 전수 커버",
  "type": "object",
  "required": ["count", "verdict"],
  "additionalProperties": false,
  "properties": {
    "count": {
      "type": "number",
      "minimum": 0,
      "description": "changes.new_features 신규 id 중 매뉴얼에서 섹션이 없거나 알맹이(무엇/왜·어떻게)가 빈 껍데기인 개수. minimize, ==0 이면 통과"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "revise"],
      "description": "pass = count == 0"
    },
    "offenders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "누락된 신규 feature id 목록"
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["where", "problem", "fix"],
        "additionalProperties": false,
        "properties": {
          "where": { "type": "string", "description": "누락 신규 id" },
          "problem": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    }
  }
}
