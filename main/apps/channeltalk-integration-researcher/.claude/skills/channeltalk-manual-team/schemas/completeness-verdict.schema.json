{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "completeness verdict — changes 신규 id 전수 커버",
  "type": "object",
  "required": ["count", "verdict"],
  "additionalProperties": false,
  "properties": {
    "count": {
      "type": "number",
      "minimum": 0,
      "description": "changes.new_features 신규 id 중 매뉴얼에서 섹션이 없거나 알맹이(무엇/왜·어떻게)가 빈 껍데기인 개수. minimize, ==0 이면 통과"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "revise"],
      "description": "pass = count == 0"
    },
    "offenders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "누락된 신규 feature id 목록"
    },
    "checked": {
      "type": "array",
      "items": { "type": "string" },
      "description": "실제로 무엇을 대조했는지 검증 흔적 (예: 'changes.new_features 22 id 전수를 매뉴얼 섹션 제목과 대조', '각 섹션 무엇/왜 + 어떻게 알맹이 존재 확인'). 채점을 실제로 수행했다는 근거이므로 비워두지 않는다."
    },
    "sampled_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "매뉴얼 섹션 존재·알맹이를 실제로 확인한 feature id 표본 (전수면 전수 id)."
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["where", "problem", "fix"],
        "additionalProperties": false,
        "properties": {
          "where": { "type": "string", "description": "누락 신규 id" },
          "problem": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    }
  }
}
