{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channeltalk/verdict.schema.json",
  "title": "out/<run>/manual-verdict.json — checker 채점(결정적 verify + 감독관)",
  "type": "object",
  "required": ["round", "verdict", "missed"],
  "additionalProperties": false,
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accurate": { "type": "number", "minimum": 0, "maximum": 10 },
        "complete": { "type": "number", "minimum": 0, "maximum": 10 },
        "privacy_safe": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "weighted": { "type": "number", "minimum": 0, "maximum": 10 },
    "verdict": { "type": "string", "enum": ["approve", "revise"] },
    "missed": {
      "type": "array",
      "description": "결정적 verify 가 지목한 누락/누출 항목",
      "items": {
        "type": "object",
        "required": ["id", "reason"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string", "enum": ["missing_feature", "missing_pii_notice", "secret_leak"] },
          "detail": { "type": "string" }
        }
      }
    },
    "fabricated": { "type": "array", "items": { "type": "string" } },
    "privacy_gaps": { "type": "array", "items": { "type": "string" } },
    "fixes": { "type": "array", "items": { "type": "string" } }
  }
}
