// 템플릿: verification-gated maker→checker 루프 (아키텍트가 <x>·<cond>·게이트를 채운다)
// 규약: top-level return/await 허용(런타임 async-wrap). Date.now()/Math.random()/fs 금지.
export const meta = {
  name: '<x>-loop',
  description: '<x> 산출을 verification-gated로 도는 루프 (maker→checker N, keep-best, run ledger, 종료조건). 역할은 코드가 spawn.',
  phases: [{ title: 'Make' }, { title: 'Debate' }],
}

// args 는 런타임에서 JSON 문자열로 도착할 수 있다 → 항상 객체로 정규화
const A = (() => { try { return typeof args === 'string' ? JSON.parse(args) : (args || {}) } catch (e) { return {} } })()

// ── 바인딩 (A override) ──
const TOPIC = A.topic || '<기본 주제>'
const SEED  = A.brief ? (typeof A.brief === 'string' ? A.brief : JSON.stringify(A.brief, null, 2)) : ''
const MAX_ROUNDS = A.max_rounds || 3
const GATE_A = A.gate_a || 8.0   // success_condition A 임계값
// const GATE_B = A.gate_b || 0   // 카운트형이면 ==0 게이트

// ── 스키마 (인라인) ──
const MAKE_SCHEMA = { type: 'object', required: ['items'], additionalProperties: true,
  properties: { items: { type: 'array', items: { type: 'object' } }, rewrite_note: { type: 'string' } } }
const A_SCHEMA = { type: 'object', required: ['score_a', 'verdict'], additionalProperties: true,
  properties: { score_a: { type: 'number' }, verdict: { type: 'string', enum: ['pass', 'revise'] },
    fixes: { type: 'array', items: { type: 'object' } } } }

// ── 인라인 역할 프롬프트 (정본: agents/<x>-*.md 압축) ──
const makePrompt = (seed) => `너는 <x> maker다. 아래로 산출을 만든다. 사실 보존(지어내기 금지), 범위 정직.\n[재료]\n${seed}\n출력: {items:[...]} JSON만.`
const rewritePrompt = (best, aFix) => `너는 maker다. best를 심판 지시만 반영해 재작성(통과분 유지, 사실 불변).\n[best]\n${JSON.stringify(best)}\n[A 심판 처방]\n${JSON.stringify(aFix || [])}\n출력: {items:[...]} JSON만.`
const aPrompt = (items, round) => `너는 <cond_a> 심판(checker)다. 받은 산출을 신선하게 0~10 채점만(후하게 금지). >=${GATE_A} pass.\n[items · round ${round}]\n${JSON.stringify(items)}\n출력 JSON: {score_a,verdict,fixes:[...]}`

// ── 1) Make ──
phase('Make')
const draft = await agent(makePrompt(SEED || TOPIC), { label: 'maker:draft', phase: 'Make', schema: MAKE_SCHEMA })
let cur = draft && draft.items ? draft.items : []
log(`초안 ${cur.length}개`)

// ── 2) Debate (keep-best, ledger, 종료조건) ──
phase('Debate')
let best = { items: cur, q: -1e9 }
const ledger = []
let prevQ = null, noImprove = 0
for (let round = 1; round <= MAX_ROUNDS; round++) {
  const [av] = await parallel([
    () => agent(aPrompt(cur, round), { label: `A:R${round}`, phase: 'Debate', schema: A_SCHEMA }),
  ])
  const a = av ? (av.score_a || 0) : 0
  const q = a                                   // 여러 축이면 q = Σgain − Σpenalty
  ledger.push({ round, a, q: Math.round(q * 100) / 100 })
  log(`R${round}  A ${a} · q ${q}`)
  if (q > best.q) best = { items: cur, q }       // keep-best
  if (a >= GATE_A) { log(`R${round} ✓ 게이트 통과`); break }
  if (prevQ !== null && q <= prevQ + 1e-9) noImprove++; else noImprove = 0
  prevQ = q
  if (noImprove >= 2) { log('조기 종료 (2R 비개선)'); break }
  if (round === MAX_ROUNDS) { log('max 라운드'); break }
  const rw = await agent(rewritePrompt(best.items, av && av.fixes), { label: `maker:R${round}`, phase: 'Debate', schema: MAKE_SCHEMA })
  cur = rw && rw.items ? rw.items : best.items
}

return { topic: TOPIC, ledger, best_q: best.q, finalItems: best.items }
