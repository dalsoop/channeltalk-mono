{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channeltalk-plugin-judge/synthesis.schema.json",
  "title": "종합 심판 산출 (패널 verdict 종합 → 가중 점수 + 1등 간극 진단)",
  "type": "object",
  "required": ["weighted_overall", "verdict_band", "dimension_rollup", "critical_weaknesses", "gap_to_first", "win_probability", "honest_bottom_line"],
  "additionalProperties": false,
  "properties": {
    "weighted_overall": { "type": "number", "minimum": 0, "maximum": 10, "description": "축 가중합(rubric 가중치)" },
    "verdict_band": { "type": "string", "enum": ["likely_winner", "strong", "competitive", "not_ready"] },
    "dimension_rollup": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["dimension", "weight", "consensus_score", "spread", "note"],
        "additionalProperties": false,
        "properties": {
          "dimension": {
            "type": "string",
            "enum": ["problem_value", "usability_fit", "technical_rigor", "ai_native", "differentiation", "honesty_presentation"]
          },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "consensus_score": { "type": "number", "minimum": 0, "maximum": 10 },
          "spread": { "type": "string", "description": "심사관 간 점수 범위 (예: 6.0~8.5) — 이견 크면 표기" },
          "note": { "type": "string" }
        }
      }
    },
    "top_strengths": { "type": "array", "items": { "type": "string" } },
    "critical_weaknesses": {
      "type": "array",
      "description": "1등을 막는 것들. 여러 심사관이 독립적으로 지목했으면 신뢰도↑",
      "items": {
        "type": "object",
        "required": ["issue", "raised_by", "evidence", "impact_on_rank"],
        "additionalProperties": false,
        "properties": {
          "issue": { "type": "string" },
          "raised_by": { "type": "array", "items": { "type": "string" }, "description": "지목한 심사관들 (독립 중복 = 강한 신호)" },
          "evidence": { "type": "string" },
          "impact_on_rank": { "type": "string" }
        }
      }
    },
    "gap_to_first": { "type": "string", "description": "1등이 되려면 구체적으로 무엇이 달라져야 하는가 (진단 — 실제 수정은 안 함)" },
    "win_probability": { "type": "string", "enum": ["low", "medium", "high"], "description": "현 상태로 1등 가능성" },
    "win_probability_rationale": { "type": "string" },
    "honest_bottom_line": { "type": "string", "description": "제출자에게 하는 정직한 한 문단 — 과장·위로 없이" },
    "rubric_caveat": { "type": "string", "description": "이 판정은 합성 루브릭 기반임을 명시 (공식 배점 미상)" }
  }
}
