{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channeltalk-plugin-judge/panel-verdict.schema.json",
  "title": "한 심사관의 채점 산출 (maker≠checker: 대상을 직접 읽고 채점)",
  "type": "object",
  "required": ["judge", "dimension_scores", "weaknesses", "win_blocker", "lens_summary"],
  "additionalProperties": false,
  "properties": {
    "judge": {
      "type": "string",
      "enum": ["hackathon-judge", "domain-pm-reviewer", "senior-architect-reviewer", "redteam-skeptic", "ax-ai-native-reviewer"]
    },
    "dimension_scores": {
      "type": "array",
      "description": "이 심사관 렌즈로 채점한 축(들). 담당 축은 필수, 그 외 축도 관점 있으면 채점 가능.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "score", "evidence", "reason"],
        "additionalProperties": false,
        "properties": {
          "dimension": {
            "type": "string",
            "enum": ["problem_value", "usability_fit", "technical_rigor", "ai_native", "differentiation", "honesty_presentation"]
          },
          "score": { "type": "number", "minimum": 0, "maximum": 10 },
          "evidence": { "type": "string", "description": "file:line 또는 실행 출력 인용 (근거 없는 점수 금지)" },
          "reason": { "type": "string" }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "재현·인용으로 확인된 강점만"
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "issue", "evidence"],
        "additionalProperties": false,
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "issue": { "type": "string" },
          "evidence": { "type": "string", "description": "file:line·실행출력·재현절차" },
          "fix_hint": { "type": "string", "description": "진단만 — 참고용 방향(선택). 이 앱은 고치지 않는다." }
        }
      }
    },
    "win_blocker": { "type": "string", "description": "이 렌즈에서 1등을 막는 가장 큰 단일 요인" },
    "lens_summary": { "type": "string", "description": "이 심사관의 3~5문장 총평" }
  }
}
