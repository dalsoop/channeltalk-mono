{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent team spec — 공장이 찍을 maker→checker 에이전트 팀의 설계",
  "type": "object",
  "required": ["name", "purpose", "maker", "success_conditions", "checkers"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "description": "팀 슬러그 (kebab-case, 예: 'thumbnail-team')" },
    "purpose": { "type": "string", "description": "이 에이전트 팀이 한 줄로 무엇을 하는가" },
    "domain_ssot": { "type": "string", "description": "도메인 기준의 정본(있으면 경로/URL). 없으면 architect가 references/<x>-philosophy.md를 만든다" },
    "maker": {
      "type": "object",
      "required": ["role", "output"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "description": "maker의 한 역할(일하는 에이전트)" },
        "input": { "type": "string", "description": "maker가 받는 입력" },
        "output": { "type": "string", "description": "maker 산출(렌더/파일/JSON 등)" }
      }
    },
    "success_conditions": {
      "type": "array",
      "description": "이 산출이 '좋다'의 실측 조건들 — 각 조건이 생성될 checker의 채점축이 된다",
      "items": {
        "type": "object",
        "required": ["name", "metric", "gate"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "조건명 (예: resonance, accuracy, latency)" },
          "metric": { "type": "string", "description": "무엇을 0~10 또는 카운트로 재나" },
          "direction": { "type": "string", "enum": ["maximize", "minimize"], "default": "maximize" },
          "gate": { "type": "number", "description": "통과 임계값 (예: >=8.0, 또는 ==0)" }
        }
      }
    },
    "checkers": {
      "type": "array",
      "description": "생성할 검사도구(신선 채점 에이전트) 목록 — success_conditions를 다른 렌즈로 본다",
      "items": {
        "type": "object",
        "required": ["name", "lens"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "checker 슬러그 (예: '<x>-clarity-reviewer')" },
          "lens": { "type": "string", "description": "이 checker가 보는 단일 렌즈" }
        }
      }
    },
    "render_or_run": { "type": "string", "description": "최종 산출을 어떻게 실현하나 (MCP 툴/스크립트/없음)" },
    "max_rounds": { "type": "integer", "default": 3, "description": "생성물 루프의 최대 라운드" }
  }
}
