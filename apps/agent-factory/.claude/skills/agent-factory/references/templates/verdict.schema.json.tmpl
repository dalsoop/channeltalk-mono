{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "<Cond> verdict over <x> 산출",
  "type": "object",
  "required": ["score_<cond>", "verdict"],
  "additionalProperties": false,
  "properties": {
    "score_<cond>": { "type": "number", "minimum": 0, "maximum": 10, "description": "<무엇을 잰다>. >= <gate> 이면 통과" },
    "verdict": { "type": "string", "enum": ["pass", "revise"], "description": "pass = score_<cond> >= <gate>" },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["where", "problem", "fix"],
        "additionalProperties": false,
        "properties": {
          "where":   { "type": "string", "description": "산출 내 위치(카드번호/줄 등)" },
          "problem": { "type": "string" },
          "fix":     { "type": "string" },
          "id":      { "type": "string", "description": "도메인 룰북 tell id (선택)" }
        }
      }
    }
  }
}
